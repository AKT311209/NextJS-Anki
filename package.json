{
    "name": "nextjs-anki",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build --turbopack",
        "start": "next start",
        "lint": "eslint src tests --max-warnings=0",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "postinstall": "node -e \"const fs=require('fs');const src='node_modules/fsrs-browser/fsrs_browser_bg.wasm';const dest='public/wasm/fsrs_browser_bg.wasm';if(fs.existsSync(src)){fs.mkdirSync('public/wasm',{recursive:true});fs.copyFileSync(src,dest)}\""
    },
    "dependencies": {
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "comlink": "^4.4.2",
        "fflate": "^0.8.2",
        "fsrs-browser": "^5.2.0",
        "katex": "^0.16.44",
        "lucide-react": "^0.468.0",
        "next": "^16.2.1",
        "next-pwa": "^5.6.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sql.js": "^1.13.0",
        "tailwind-merge": "^2.5.5",
        "wa-sqlite": "^1.0.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4.1.3",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^22.13.10",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@types/sql.js": "^1.4.11",
        "@vitejs/plugin-react": "^4.4.1",
        "eslint": "^9.22.0",
        "eslint-config-next": "^16.2.1",
        "jsdom": "^26.0.0",
        "playwright": "^1.58.2",
        "shadcn": "^4.1.1",
        "tailwindcss": "^4.1.3",
        "typescript": "^5.8.2",
        "vitest": "^4.1.2"
    }
}
